<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="UTF-8">
	<title>iClassifier reports page</title>

	<!-- Fonts and styles -->
	<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC&display=swap" rel="stylesheet">
	<link href="https://fonts.googleapis.com/css2?family=Raleway:wght@500&display=swap" rel="stylesheet">
	<link rel="stylesheet" href="{{ css_path }}/style.css">
	<link rel="stylesheet" href="{{ css_path }}/components.css">

	<!-- Handsontable -->
	<script src="{{ js_path }}/handsontable/handsontable.full.min.js"></script>
	<link rel="stylesheet" type="text/css" href="{{ js_path }}/handsontable/handsontable.full.min.css">

	<!-- JavaScript -->
	<script src="{{ js_path }}/mdc2uni.js"></script>
	<script src="{{ js_path }}/vis.js"></script>
	<script src="{{ js_path }}/mithril.js"></script>
	<script src="{{ js_path }}/components.js"></script>
	<script src="{{ js_path }}/main.js"></script>
	<script src="{{ js_path }}/thesauri.js"></script>
	<script src="{{ js_path }}/clfreport.js"></script>
	<script src="{{ js_path }}/clfqueries.js"></script>
	<script src="{{ js_path }}/lemmareport.js"></script>
	<script src="{{ js_path }}/tokenstats.js"></script>
	<script src="{{ js_path }}/map.js"></script>
	<script src="{{ js_path }}/view.js"></script>
</head>

<body>
	<header
		style="display: flex; justify-content: space-between; background-color: black; vertical-align: middle; width: 100%; margin: 0; margin-bottom: 10px; padding-left: 20px;">
		<div>
			<h1 style="color: white;">Reports</h1>
		</div>
		<div style="display: block; height: 100%; margin-right: 30px;">
			<img alt="iClassifier logo" src="iclassifier-logo-new.png"
				style="height: 50px; vertical-align: middle; margin-top: 13px;">
		</div>
	</header>
	<div id="main" style="margin-top: 20px;">
		<h4><label for="project-select">Select a project:</label></h4>
		<select id="project-select" style="width: 250px; margin-left: 5px; margin-right: 15px;"
			onchange="clfCounts = {}; lemmasForClfs = {}; switchProjectWrapper(this);">
			<option value="---" disabled selected>---</option>
		</select>
		<div id="report"></div>
	</div>
	<script>
		let root = byID('report');
		m.mount(root, report);
	</script>
</body>

</html>