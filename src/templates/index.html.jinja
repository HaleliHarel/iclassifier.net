{% extends "base.html.jinja" %}
{% block title %}iClassifier logout{% endblock %}
{% block head %}
    {% if is_admin %}
    <link rel="stylesheet" href="/static/css/admin.css">
    {% endif %}
{% endblock %}
{% block body %}
    {% with messages = get_flashed_messages() %}
  {% if messages %}
    <ul class=flashes>
    {% for message in messages %}
      <li>{{ message }}</li>
    {% endfor %}
    </ul>
  {% endif %}
{% endwith %}
    <h1>iClassifier input system</h1>

    <p>{{ user_name }}’s dashboard.</p>

    <p>Projects available for editing or auditing:</p>

    <form method="POST" action="/input/project">
      <select class="project-select" name="project">
      {% for project in projects %}
        <option value="{{ project.value }}">{{ project.label }} ({{ project.access }})</option>
      {% endfor %}
      </select>
      <br/>
      <input type="submit" value="Open project">
    </form>
    <br/>

    <p>Available project reports:</p>

    <form method="POST" action="/reports/projectreport">
      <select class="project-select" name="project">
      {% for project in projects_w_reports %}
        <option value="{{ project.value }}">{{ project.label }}</option>
      {% endfor %}
      </select>
      <br/>
      <input type="submit" value="Open project report">
    </form>
    <br/>

    {% if is_admin %}
    {% include "admin_panel.html.jinja" %}
    {% endif %}

    <form method="POST" action="/input/logout">
        <input type="submit" value="Logout">
    </form>
{% endblock %}
